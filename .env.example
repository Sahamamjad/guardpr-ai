# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
DEMO_MODE=false

# Database
DATABASE_URL=postgresql://guardpr:guardpr@postgres:5432/guardpr

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=change-me-to-a-long-random-string

# AI (OpenAI — set one provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_TRIAGE_ENABLED=true

# Auth
JWT_SECRET=change-me-jwt-secret-minimum-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS / Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limiting
RATE_LIMIT_PER_MINUTE=100

# Scanning
SCANNER_TIMEOUT_SECONDS=120
MAX_FILE_SIZE_BYTES=1048576
SEMGREP_CONFIGS=p/owasp-top-ten,p/python,p/javascript

# Storage
REPORT_STORAGE_PATH=/app/storage/reports
